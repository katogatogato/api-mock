{
  "name": "api-mock",
  "version": "1.0.0",
  "description": "Spin up a local mock server from an OpenAPI spec with realistic fake data",
  "author": "katogatogato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/katogatogato/api-mock"
  },
  "keywords": [
    "mock",
    "openapi",
    "api",
    "testing",
    "fake-data",
    "server"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
